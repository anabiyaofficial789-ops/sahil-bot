{
  "name": "sahil-804-bot",
  "version": "4.0.0",
  "description": "SAHIL 804 — Pakistan Ka #1 Free WhatsApp Bot",
  "main": "src/index.js",
  "type": "commonjs",
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "start":       "node web/server.js",
    "bot":         "node src/index.js",
    "dev":         "nodemon web/server.js",
    "pm2-start":   "pm2 start web/server.js --name sahil-804 --max-restarts 10 --restart-delay 5000",
    "pm2-stop":    "pm2 stop sahil-804",
    "pm2-restart": "pm2 restart sahil-804",
    "pm2-logs":    "pm2 logs sahil-804",
    "pm2-save":    "pm2 save"
  },
  "author": "Sahil Hacker",
  "license": "MIT",
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.9",
    "axios":              "^1.7.7",
    "axios-retry":        "^4.5.0",
    "body-parser":        "^1.20.3",
    "chalk":              "^4.1.2",
    "compression":        "^1.7.4",
    "dotenv":             "^16.4.5",
    "express":            "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "express-session":    "^1.18.1",
    "fs-extra":           "^11.2.0",
    "helmet":             "^8.0.0",
    "node-cache":         "^5.1.2",
    "pino":               "^9.5.0",
    "pino-pretty":        "^11.0.0",
    "pm2":                "^5.4.3",
    "qrcode":             "^1.5.4",
    "socket.io":          "^4.7.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.7"
  }
}
