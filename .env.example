# ============================================
# SAHIL 804 WhatsApp Bot - Environment Config
# Developer: Sahil Hacker | v4.0.0
# ⚠️ DO NOT SHARE THIS FILE
# Rename to .env and fill in your values
# ============================================

# ── Server Settings ──────────────────────────
PORT=8000
SESSION_SECRET=sahil804_change_this_random_string_abc123
WEBSITE_URL=https://your-domain.com

# ── Bot Settings ──────────────────────────────
BOT_NAME=SAHIL 804
BOT_PREFIX=.

# ── Admin Panel Password ──────────────────────
# Change this to a strong password!
ADMIN_PASSWORD=sahil804admin_change_this_password

# ── RapidAPI Key ──────────────────────────────
# Free key from: https://rapidapi.com
# Required for: YouTube MP3 download (.ytmp3)
# All other downloads work WITHOUT this key.
# If empty, users see a clear error message.
RAPIDAPI_KEY=

# ── Features (true/false) ────────────────────
AUTO_REACT=true
AUTO_REPLY=true
AUTO_READ=true
ANTI_DELETE=true
WELCOME_MSG=true
GOODBYE_MSG=true
ANTI_SPAM=true
ANTI_LINK=false
ANTI_BOT=true

# ════════════════════════════════════════════
# ⚠️  HOSTING NOTES
# ════════════════════════════════════════════
#
# Railway (recommended for free hosting):
#   - Sessions persist within a deployment
#   - Sessions ARE LOST on every redeploy
#   - To keep sessions: use Railway's Volume
#     storage (paid) or re-pair after each deploy
#   - Sticker command (.sticker) WORKS on Railway
#     because Docker build tools are available
#
# Hostinger Shared Hosting:
#   - Sessions persist (normal filesystem)
#   - Sticker command may FAIL — sharp/ffmpeg
#     native binaries may not compile
#   - Recommend VPS plan for full features
#
# VPS (Ubuntu/Debian) — Best option:
#   - All features work
#   - Sessions persist indefinitely
#   - Run: npm install && npm run pm2-start
#
# ════════════════════════════════════════════
